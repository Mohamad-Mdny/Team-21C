<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="backend.controllers.CatalogueController">

   <top>
      <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
         <HBox>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="IPOS-PU" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" text="Surya did this idk" />
         </HBox>

         <StackPane>
            <TextField fx:id="searchField" maxWidth="420.0" prefWidth="420.0" promptText="Search catalogue..." />
         </StackPane>

         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button mnemonicParsing="false" onAction="#goToCatalogue" text="Catalogue" />
            <Button mnemonicParsing="false" onAction="#goToCurrentPromotions" text="Current Promotions" />

            <Region HBox.hgrow="ALWAYS" />

            <Button mnemonicParsing="false" onAction="#goToCheckout" text="Checkout" />
            <Button fx:id="accountButton" mnemonicParsing="false" onAction="#handleAccountButton" text="Account Settings" />
         </HBox>
      </VBox>
   </top>

   <left>
      <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #f3f4f6; -fx-padding: 16; -fx-border-color: #d1d5db; -fx-border-width: 0 1 0 0;">
         <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Filters" />

         <CheckBox fx:id="inStockOnly" text="In stock only" />
         <CheckBox fx:id="lowStockOnly" text="Low stock only" />

         <Label text="Package Type" />
         <ComboBox fx:id="packageTypeFilter" promptText="All package types" />

         <Label text="Unit" />
         <ComboBox fx:id="unitFilter" promptText="All units" />

         <Label text="Maximum price" />
         <TextField fx:id="maxPriceField" promptText="e.g. 1.50" />

         <Button mnemonicParsing="false" onAction="#clearFilters" text="Clear Filters" />
         <Label fx:id="memberSession" prefHeight="42.0" prefWidth="108.0" />
      </VBox>
   </left>

   <center>
      <BorderPane style="-fx-padding: 12;">
         <top>
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
               <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Catalogue" />
            </HBox>
         </top>

         <center>
            <ScrollPane fx:id="catalogueScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true"
                        style="-fx-background-color: transparent;">
               <GridPane fx:id="catalogueGrid" hgap="16.0" style="-fx-background-color: white;" vgap="16.0">
                  <padding>
                     <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                  </padding>
               </GridPane>
            </ScrollPane>
         </center>
      </BorderPane>
   </center>
</BorderPane>
