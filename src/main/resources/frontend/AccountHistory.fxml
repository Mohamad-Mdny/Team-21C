<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.controllers.AccountHistoryController">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label text="IPOS-PU"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Order History"
                       style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" />
            </HBox>

            <StackPane>
                <TextField fx:id="searchField"
                           maxWidth="420.0"
                           prefWidth="420.0"
                           promptText="Search catalogue..."
                           onAction="#handleSearchEnter" />
            </StackPane>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" text="Catalogue" onAction="#goToCatalogue" />
                <Button mnemonicParsing="false" text="Current Promotions" onAction="#goToCurrentPromotions" />

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" text="Basket" onAction="#goToBasket" />
                <Button mnemonicParsing="false" text="Back" onAction="#goToAccountSettings" />

            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="18.0" style="-fx-padding: 24;">

                    <VBox spacing="10.0"
                          style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label text="Order History"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                        <Label text="All orders associated with your account."
                               style="-fx-text-fill: #4b5563;" />

                        <TableView fx:id="orderHistory" prefHeight="260.0">
                            <columns>
                                <TableColumn fx:id="OrderID" prefWidth="120.0" text="Order ID" />
                                <TableColumn fx:id="Descriptions" prefWidth="520.0" text="Description" />
                                <TableColumn fx:id="EmailAddress" prefWidth="260.0" text="Email Address" />
                                <TableColumn fx:id="DeliveryAddress" prefWidth="260.0" text="Delivery Address" />


                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="10.0"
                          style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label text="Transaction History"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                        <Label text="Card payments recorded against your account."
                               style="-fx-text-fill: #4b5563;" />

                        <TableView fx:id="transactionHistory" prefHeight="260.0">
                            <columns>
                                <TableColumn fx:id="transactionID" prefWidth="140.0" text="Transaction ID" />
                                <TableColumn fx:id="amount" prefWidth="140.0" text="Amount" />
                                <TableColumn fx:id="transactionEmailAddress" prefWidth="320.0" text="Email Address" />
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>