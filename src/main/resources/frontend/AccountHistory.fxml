<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="backend.controllers.AccountHistoryController">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="IPOS-PU" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" text="Order History" />
            </HBox>

            <StackPane>
                <TextField fx:id="searchField" maxWidth="420.0" onAction="#handleSearchEnter" prefWidth="420.0" promptText="Search catalogue..." />
            </StackPane>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button mnemonicParsing="false" onAction="#goToCatalogue" text="Catalogue" />
                <Button mnemonicParsing="false" onAction="#goToCurrentPromotions" text="Current Promotions" />

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#goToBasket" text="Basket" />
                <Button mnemonicParsing="false" onAction="#goToAccountSettings" text="Back" />

            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="18.0" style="-fx-padding: 24;">

                    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Order History" />
                        <Label style="-fx-text-fill: #4b5563;" text="All orders associated with your account." />

                        <TableView fx:id="orderHistory" prefHeight="260.0">
                            <columns>
                                <TableColumn fx:id="OrderID" prefWidth="120.0" text="Order ID" />
                                <TableColumn fx:id="Descriptions" prefWidth="520.0" text="Description" />
                                <TableColumn fx:id="EmailAddress" prefWidth="260.0" text="Email Address" />
                                <TableColumn fx:id="DeliveryAddress" prefWidth="221.00006103515625" text="Delivery Address" />
                        <TableColumn fx:id="OrderStatus" prefWidth="75.0" text="Order Status" />


                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Transaction History" />
                        <Label style="-fx-text-fill: #4b5563;" text="Card payments recorded against your account." />

                        <TableView fx:id="transactionHistory" prefHeight="260.0">
                            <columns>
                                <TableColumn fx:id="transactionID" prefWidth="140.0" text="Transaction ID" />
                                <TableColumn fx:id="amount" prefWidth="140.0" text="Amount" />
                                <TableColumn fx:id="transactionEmailAddress" prefWidth="320.0" text="Email Address" />
                        <TableColumn fx:id="purchaseDate" prefWidth="150.39996337890625" text="Purchase Date" />
                        <TableColumn fx:id="billingAddress" minWidth="0.0" prefWidth="133.0" text="Billing Address" />
                        <TableColumn fx:id="cardNumber" minWidth="0.0" prefWidth="185.39996337890625" text="card Number" />
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
