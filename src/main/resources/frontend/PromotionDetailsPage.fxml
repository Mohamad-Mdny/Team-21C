<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="backend.prm.frontend.PromotionDetailsPageController"
            prefWidth="1000.0"
            prefHeight="700.0"
            style="-fx-background-color: #f4f7fb;">

    <top>
        <VBox spacing="10.0" style="-fx-background-color: #1f2937; -fx-padding: 24;">
            <Label text="IPOS-PU"
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />

            <HBox alignment="CENTER_LEFT">
                <Button text="Back"
                        mnemonicParsing="false"
                        onAction="#handleBack" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" style="-fx-padding: 24;">
            <VBox spacing="8.0"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
                <Label fx:id="titleLabel"
                       text="Campaign Title"
                       style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #111827;" />

                <Label fx:id="descriptionLabel"
                       text="Campaign description"
                       wrapText="true"
                       style="-fx-font-size: 14px; -fx-text-fill: #4b5563;" />

                <HBox spacing="20.0">
                    <Label fx:id="statusLabel"
                           text="Status: ACTIVE"
                           style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #374151;" />
                    <Label fx:id="startLabel"
                           text="Start: -"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151;" />
                    <Label fx:id="endLabel"
                           text="End: -"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151;" />
                </HBox>
            </VBox>

            <VBox spacing="14.0" VBox.vgrow="ALWAYS">
                <Label fx:id="itemsCountLabel"
                       text="0 products in this campaign"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #374151;" />

                <ListView fx:id="itemsListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" />
            </VBox>
        </VBox>
    </center>

</BorderPane>