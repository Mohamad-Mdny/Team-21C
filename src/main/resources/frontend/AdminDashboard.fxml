<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="backend.prm.frontend.AdminDashboardController"
      fx:id="rootPane"
      onMouseClicked="#handleRootClick"
      spacing="16"
      style="-fx-background-color: #f5f7fb;">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Promotion Admin Dashboard"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel"
               text="Ready"
               style="-fx-text-fill: #4b5563; -fx-font-size: 13px;"/>
    </HBox>

    <Label fx:id="toastLabel"
           text=""
           visible="false"
           managed="false"
           style="-fx-padding: 8 12 8 12; -fx-background-radius: 8; -fx-font-weight: bold;"/>

    <SplitPane dividerPositions="0.22,0.68" VBox.vgrow="ALWAYS">

        <VBox spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Campaigns" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#handleRefreshCampaigns"/>
            </HBox>

            <ListView fx:id="campaignListView" VBox.vgrow="ALWAYS"/>

            <Button fx:id="createCampaignButton"
                    text="Create New Campaign"
                    onAction="#handleCreateNewCampaign"
                    maxWidth="1.7976931348623157E308"/>
        </VBox>

        <VBox spacing="14"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16;">
            <Label fx:id="selectedCampaignLabel"
                   text="No campaign selected"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="75"/>
                </columnConstraints>

                <Label text="Title" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="titleField"
                           promptText="Campaign title"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionArea"
                          prefRowCount="4"
                          wrapText="true"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Start date" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <DatePicker fx:id="startDatePicker"
                            GridPane.rowIndex="2"
                            GridPane.columnIndex="1"/>

                <Label text="End date" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <DatePicker fx:id="endDatePicker"
                            GridPane.rowIndex="3"
                            GridPane.columnIndex="1"/>

                <Label text="Campaign discount %" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="campaignDiscountField"
                           promptText="Example: 15"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button fx:id="editCampaignButton" text="Edit" onAction="#handleEditCampaign"/>
                <Button fx:id="saveCampaignButton" text="Save" onAction="#handleSaveCampaign"/>
                <Button fx:id="cancelCampaignButton" text="Cancel Edit" onAction="#handleCancelCampaignEdit"/>
                <Button fx:id="deleteCampaignButton" text="Delete" onAction="#handleDeleteCampaign"/>
                <Button fx:id="stopCampaignButton"
                        text="Cancel Campaign"
                        onAction="#handleStopCampaign"
                        visible="false"
                        managed="false"/>
                <Button fx:id="reactivateCampaignButton"
                        text="Reactivate"
                        onAction="#handleReactivateCampaign"
                        visible="false"
                        managed="false"/>
            </HBox>

            <Separator/>

            <Label fx:id="itemsCampaignLabel"
                   text="No campaign selected"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">
                <VBox spacing="10"
                      style="-fx-background-color: #fafafa; -fx-background-radius: 12; -fx-padding: 12;">
                    <Label text="Campaign Items" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <ListView fx:id="itemsListView" VBox.vgrow="ALWAYS"/>

                    <VBox fx:id="itemDetailsBox"
                          spacing="6"
                          visible="false"
                          managed="false"
                          style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="Selected item details" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                        <Label text="Item ID:"/>
                        <Label fx:id="selectedItemIdLabel" text="-"/>

                        <Label text="Product ID:"/>
                        <Label fx:id="selectedItemProductIdLabel" text="-"/>

                        <Label text="Promo price:"/>
                        <Label fx:id="selectedItemPriceLabel" text="-"/>

                        <Label text="Stats:"/>
                        <Label fx:id="selectedItemStatsLabel" text="-"/>

                        <Label text="Edit product ID:"/>
                        <TextField fx:id="editItemProductIdField" promptText="Product ID"/>

                        <HBox spacing="8">
                            <Button fx:id="saveItemButton" text="Save" onAction="#handleSaveItemChanges"/>
                            <Button fx:id="cancelItemEditButton" text="Cancel" onAction="#handleCancelItemEdit"/>
                            <Button fx:id="deleteItemButton" text="Delete" onAction="#handleDeleteSelectedItem"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color: #fafafa; -fx-background-radius: 12; -fx-padding: 12;">
                    <Label text="Add product to campaign" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <TextField fx:id="productSearchField" promptText="Search by ID or description"/>

                    <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="productIdColumn" text="Product ID" prefWidth="120"/>
                            <TableColumn fx:id="productDescriptionColumn" text="Description" prefWidth="260"/>
                            <TableColumn fx:id="productPriceColumn" text="Price" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <Button fx:id="addSelectedProductButton"
                            text="Add Selected Product"
                            onAction="#handleAddSelectedProductToCampaign"
                            maxWidth="1.7976931348623157E308"/>
                </VBox>
            </SplitPane>
        </VBox>

        <VBox spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16;">
            <Label text="Reports" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Start date"/>
                <DatePicker fx:id="reportStartDatePicker"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="End date"/>
                <DatePicker fx:id="reportEndDatePicker"/>
            </HBox>

            <HBox spacing="8">
                <Button text="Sales Report" onAction="#handleGenerateSalesReport"/>
                <Button text="Campaign Report" onAction="#handleGenerateCampaignReport"/>
                <Button text="Hits Report" onAction="#handleGenerateHitsReport"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
                <content>
                    <VBox spacing="14"
                          style="-fx-background-color: #fcfcfd; -fx-padding: 16; -fx-background-radius: 12;">
                        <Label fx:id="reportTitleLabel"
                               text="Report preview"
                               maxWidth="1.7976931348623157E308"
                               alignment="CENTER"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-alignment: center;"/>

                        <HBox alignment="TOP_RIGHT">
                            <VBox alignment="TOP_RIGHT"
                                  style="-fx-padding: 2 0 0 0;">
                                <Label fx:id="reportAddressLabel"
                                       text=""
                                       wrapText="true"
                                       alignment="TOP_RIGHT"
                                       maxWidth="220"
                                       style="-fx-font-size: 13px; -fx-text-alignment: right;"/>
                            </VBox>
                        </HBox>

                        <VBox fx:id="reportMetaBox"
                              spacing="4"
                              style="-fx-padding: 4 0 8 0;"/>

                        <TextArea fx:id="reportBodyArea"
                                  prefRowCount="18"
                                  editable="false"
                                  wrapText="false"
                                  style="-fx-font-family: 'Consolas'; -fx-font-size: 12px;"
                                  VBox.vgrow="ALWAYS"/>

                        <VBox spacing="2">
                            <Label fx:id="reportGeneratedLabel" text="" style="-fx-font-size: 12px;"/>
                            <Label fx:id="reportGeneratedByLabel" text="" style="-fx-font-size: 12px;"/>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>

    </SplitPane>
</VBox>

