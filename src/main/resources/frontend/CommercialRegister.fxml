<?xml version="1.0" encoding="UTF-8"?> <?import javafx.scene.control.*?> <?import javafx.scene.layout.*?>
<BorderPane prefHeight="700.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.controllers.RegisterController">
    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label text="IPOS-PU" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Commercial Registration" style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;"/>
            </HBox>
            <StackPane>
                <TextField fx:id="searchField" maxWidth="420.0" prefWidth="420.0" promptText="Search catalogue..."/>
            </StackPane>
            <HBox spacing="10.0"
                  alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" text="Catalogue" onAction="#goToCatalogue"/>
                <Button mnemonicParsing="false" text="Current Promotions" onAction="#goToCurrentPromotions"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" text="Basket" onAction="#goToBasket"/>
                <Button mnemonicParsing="false" text="Sign In" onAction="#goToLogin"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <StackPane style="-fx-padding: 40;">
                    <VBox spacing="14.0" alignment="CENTER" maxWidth="640.0"
                          style="-fx-background-color: white; -fx-padding: 28; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label text="Apply for a commercial account"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="Enter your company details below. Your application will be forwarded to InfoPharma (IPOS-SA)."
                               wrapText="true" style="-fx-text-fill: #4b5563;"/>
                        <Separator/>
                        <GridPane hgap="14" vgap="12" maxWidth="560.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="180" prefWidth="200"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="Email" style="-fx-font-weight: bold;" GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>
                            <TextField fx:id="email" promptText="Enter Email" GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>
                            <Label text="Company Registration No." style="-fx-font-weight: bold;" GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>
                            <TextField fx:id="CompanyRegistration" promptText="Enter Company Registration Number"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Company Director" style="-fx-font-weight: bold;" GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>
                            <TextField fx:id="CompanyDirector" promptText="Enter Company Director" GridPane.rowIndex="2"
                                       GridPane.columnIndex="1"/>
                            <Label text="Type of Business" style="-fx-font-weight: bold;" GridPane.rowIndex="3"
                                   GridPane.columnIndex="0"/>
                            <TextField fx:id="typeOfBusiness" promptText="Enter type of business" GridPane.rowIndex="3"
                                       GridPane.columnIndex="1"/>
                            <Label text="Business Address" style="-fx-font-weight: bold;" GridPane.rowIndex="4"
                                   GridPane.columnIndex="0"/>
                            <TextField fx:id="businessAddress" promptText="Enter business address" GridPane.rowIndex="4"
                                       GridPane.columnIndex="1"/>
                        </GridPane>
                        <Button text="Submit Application" mnemonicParsing="false" maxWidth="Infinity"
                                onAction="#submitCommercialApplication"
                                style="-fx-font-weight: bold; -fx-padding: 10 0 10 0;"/>
                        <Label fx:id="errorLabel" text="" wrapText="true"
                               style="-fx-text-fill: #b91c1c; -fx-font-size: 13px;"/>
                    </VBox>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>