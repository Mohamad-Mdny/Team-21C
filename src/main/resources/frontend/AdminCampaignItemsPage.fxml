<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.prm.frontend.AdminCampaignItemsPageController">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label fx:id="campaignTitleLabel" text="Campaign"/>
        </VBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="420">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <Label text="Campaign Items"/>
            <ListView fx:id="itemsListView" prefHeight="460"/>

            <Button text="Refresh" onAction="#handleRefresh"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <Label text="Add / Delete Item"/>

            <TextField fx:id="productIdField" promptText="Product ID"/>
            <TextField fx:id="discountField" promptText="Discount percent"/>

            <HBox spacing="10">
                <Button text="Add Item" onAction="#handleAddItem"/>
                <Button text="Delete Selected" onAction="#handleDeleteItem"/>
                <Button text="Close" onAction="#handleClose"/>
            </HBox>

            <Label fx:id="statusLabel" text="Ready"/>
        </VBox>
    </center>
</BorderPane>