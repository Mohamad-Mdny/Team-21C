<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="backend.prm.frontend.PromotionsPageController"
            prefWidth="1000.0"
            prefHeight="700.0"
            style="-fx-background-color: #f4f7fb;">

    <top>
        <VBox spacing="16.0" style="-fx-padding: 24;">
            <children>
                <VBox spacing="6.0"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;">
                    <children>
                        <Label text="IPOS-PU Promotions"
                               style="-fx-font-size: 14px; -fx-text-fill: #6b7280; -fx-font-weight: 700;" />
                        <Label text="Active Promotion Campaigns"
                               style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #111827;" />
                        <Label text="Browse currently active campaigns and view available promotional offers."
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: #4b5563;" />
                    </children>
                </VBox>

                <HBox spacing="12.0"
                      alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 18 20 18 20;">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Current campaigns"
                                       style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

<!--                        <Button text="Refresh"-->
<!--                                onAction="#handleRefresh"-->
<!--                                style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 10 18 10 18;" />-->
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0" style="-fx-padding: 0 24 24 24;">
            <children>
                <Label fx:id="campaignCountLabel"
                       text="0 active campaigns"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #374151;" />

                <ListView fx:id="campaignListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" />
            </children>
        </VBox>
    </center>

</BorderPane>