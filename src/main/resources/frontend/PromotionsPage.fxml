<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.prm.frontend.PromotionsPageController">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label text="IPOS-PU"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Current Promotions"
                       style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" />
            </HBox>

            <StackPane>
                <TextField fx:id="searchField"
                           maxWidth="420.0"
                           prefWidth="420.0"
                           promptText="Search catalogue..."
                           onAction="#handleSearchEnter" />
            </StackPane>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" onAction="#goToCatalogue" text="Catalogue" />
                <Button mnemonicParsing="false" onAction="#goToCurrentPromotions" text="Current Promotions" />

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#goToCheckout" text="Basket" />
                <Button fx:id="accountButton"
                        mnemonicParsing="false"
                        onAction="#handleAccountButton"
                        text="Account Settings" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="16.0" style="-fx-padding: 24;">

                    <VBox spacing="6.0">
                        <Label text="Active Campaigns"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label fx:id="campaignCountLabel"
                               text="0 active campaigns"
                               style="-fx-font-size: 13px; -fx-text-fill: #4b5563;" />
                    </VBox>

                    <VBox spacing="10.0"
                          style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                        <Label text="Select a campaign to view details and products."
                               style="-fx-text-fill: #4b5563;" />

                        <ListView fx:id="campaignListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="520.0"
                                  style="-fx-background-color: transparent; -fx-control-inner-background: #ffffff;" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>