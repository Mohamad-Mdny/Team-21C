<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="backend.prm.frontend.PromotionsPageController"
            prefWidth="1000.0"
            prefHeight="700.0"
            style="-fx-background-color: #f4f7fb;">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 24;">
            <HBox>
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="IPOS-PU" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button onAction="#goToCatalogue" text="Catalogue" />
                <Button onAction="#goToCurrentPromotions" text="Current Promotions" />
                <Button onAction="#goToAdminDashboard" text="Admin" />

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#goToNonCommercialRegister" text="NC-Signup" />
                <Button onAction="#goToCommercialRegister" text="C-Signup" />
                <Button onAction="#goToCheckout" text="Basket" />
                <Button fx:id="accountButton" onAction="#handleAccountButton" text="Account Settings" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0" style="-fx-padding: 0 24 24 24;">
            <children>
                <Label fx:id="campaignCountLabel"
                       text="0 active campaigns"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #374151;" />

                <ListView fx:id="campaignListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" />
            </children>
        </VBox>
    </center>

</BorderPane>