<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="backend.controllers.LoginController">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="IPOS-PU" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" text="Login" />
            </HBox>

            <StackPane>
                <TextField fx:id="searchField" maxWidth="420.0" onAction="#handleSearchEnter" prefWidth="420.0" promptText="Search catalogue..." />
            </StackPane>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button mnemonicParsing="false" onAction="#goToCatalogue" text="Catalogue" />
                <Button mnemonicParsing="false" onAction="#goToCurrentPromotions" text="Current Promotions" />

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#goToCheckout" text="Basket" />
                <Button fx:id="SignIn" mnemonicParsing="false" text="Sign In" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 40;">
            <VBox alignment="CENTER" maxWidth="420.0" spacing="14.0" style="-fx-background-color: white; -fx-padding: 28; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">

                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Sign in" />

                <Label style="-fx-text-fill: #4b5563;" text="Use your email and password to access your account." wrapText="true" />
                <Separator />
                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold;" text="Email" />
                    <TextField fx:id="emailInput" promptText="Enter Email" />
                </VBox>

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold;" text="Password" />
                    <PasswordField fx:id="passwordInput" onAction="#login" promptText="Enter Password" />
                </VBox>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#login" style="-fx-font-weight: bold; -fx-padding: 10 0 10 0;" text="Login" />
                <Label fx:id="errorLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="176.0" layoutY="339.0" prefHeight="19.0" prefWidth="247.0" />
            <Label prefHeight="18.0" prefWidth="147.0" text="Don't have a membership?" />
            <Button mnemonicParsing="false" onAction="#goToCommercialRegister" prefHeight="26.0" prefWidth="153.0" text="Commercial Sign up" />
            <Button mnemonicParsing="false" onAction="#goToNonCommercialRegister" prefHeight="26.0" prefWidth="155.0" text="Non-Commercial Sign up" />
            </VBox>
        </StackPane>

    </center>

</BorderPane>
