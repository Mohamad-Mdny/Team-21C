<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.controllers.AdminPageController">

    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label text="IPOS-PU"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Admin"
                       style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;" />
            </HBox>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" text="Admin Dashboard" onAction="#goToAdminDashboard" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" text="Sign out" onAction="#logout" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 40;">
            <VBox spacing="14.0"
                  alignment="CENTER"
                  maxWidth="520.0"
                  style="-fx-background-color: white; -fx-padding: 28; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">

                <Label text="VAT Settings"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <Label text="Set the VAT rate used by the portal (e.g., 0, 5, 20)."
                       wrapText="true"
                       style="-fx-text-fill: #4b5563;" />

                <Separator />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="VAT (%)" style="-fx-font-weight: bold;" />
                    <TextField fx:id="vatField" promptText="e.g. 0 or 20" prefWidth="140" />
                    <Button mnemonicParsing="false" text="Save VAT" onAction="#saveVat" />
                </HBox>

                <Label fx:id="statusLabel"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #111827;" />

            </VBox>
        </StackPane>
    </center>

</BorderPane>