<?xml version="1.0" encoding="UTF-8"?> <?import javafx.scene.control.*?> <?import javafx.scene.layout.*?>
<BorderPane prefHeight="700.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="backend.controllers.ForgetPasswordController"> <!-- TOP BAR -->
    <top>
        <VBox spacing="12.0" style="-fx-background-color: #1f2937; -fx-padding: 16;">
            <HBox>
                <Label text="IPOS-PU" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Reset Password" style="-fx-text-fill: #e5e7eb; -fx-font-size: 14px;"/>
            </HBox>
            <StackPane>
                <TextField fx:id="searchField" maxWidth="420.0" prefWidth="420.0" promptText="Search catalogue..."/>
            </StackPane>
            <HBox spacing="10.0"
                  alignment="CENTER_LEFT">
                <Button mnemonicParsing="false" text="Catalogue" onAction="#goToCatalogue"/>
                <Button mnemonicParsing="false" text="Current Promotions" onAction="#goToCurrentPromotions"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" text="Basket" onAction="#goToBasket"/>
                <Button mnemonicParsing="false" text="Sign In" onAction="#goToLogin"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <StackPane style="-fx-padding: 40;">
            <VBox spacing="14.0" alignment="CENTER" maxWidth="520.0"
                  style="-fx-background-color: white; -fx-padding: 28; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-background-radius: 12;">
                <Label text="Reset your password" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Enter your email and current password, then choose a new password." wrapText="true"
                       style="-fx-text-fill: #4b5563;"/>
                <Separator/>
                <VBox spacing="8.0" maxWidth="420.0">
                    <Label text="Email" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="emailInput" promptText="Enter Email" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="8.0" maxWidth="420.0">
                    <Label text="Current Password" style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordInput" promptText="Enter current password" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="8.0" maxWidth="420.0">
                    <Label text="New Password" style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="newPasswordInput" promptText="Enter new password" maxWidth="Infinity"/>
                </VBox>
                <Button text="Change Password" mnemonicParsing="false" maxWidth="Infinity" onAction="#changePassword"
                        style="-fx-font-weight: bold; -fx-padding: 10 0 10 0;"/>
                <Label fx:id="errorLabel" text="" wrapText="true" style="-fx-text-fill: #b91c1c; -fx-font-size: 13px;"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>